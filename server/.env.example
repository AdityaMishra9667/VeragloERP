# Copy to server/.env
DATABASE_URL=postgresql://veraglo:veraglo@localhost:5432/veraglo_erp
PORT=3000
CORS_ORIGIN=http://localhost:3000

# Easiest local run without Docker — uncomment or run: USE_FILE_STORAGE=1 ./start.sh
# USE_FILE_STORAGE=1

# Optional — Open-Meteo is used by default (no key required)
# OPENWEATHER_API_KEY=

# Optional — log OTP/reset links to server console during development
# VERAGLO_DEBUG_RESET=1

# Public URL for password reset links in emails
# APP_URL=http://localhost:3000
